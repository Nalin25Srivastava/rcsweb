    "express-rate-limit": "^8.3.2",
    "framer-motion": "^12.38.0",
    "google-auth-library": "^10.6.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^0.575.0",
    "mongoose": "^8.12.0",
    "multer": "^2.1.1",
