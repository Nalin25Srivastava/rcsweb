{
  "version": 2,
  "outputDirectory": "dist",
  "functions": {
    "api/index.js": {
      "includeFiles": "backend/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/assets/(.*)",
      "destination": "/dist/assets/$1"
    },
    {
      "source": "/images/(.*)",
      "destination": "/dist/images/$1"
    },
    {
      "source": "/vite.svg",
      "destination": "/dist/vite.svg"
    },
    {
      "source": "/(.*)",
      "destination": "/dist/index.html"
    }
  ]
}